# Database
DATABASE_URL="file:./db/prod.db"

# Authentication (Auth.js v5)
# AUTH_SECRET: Required secret for session encryption (v5 alias)
AUTH_SECRET="your-secret-key-change-in-production"

# AUTH_TRUST_HOST: Required in production when behind a proxy (Vercel, Docker, etc.)
# Set to true to trust the X-Forwarded-Host header
AUTH_TRUST_HOST=true

# AUTH_URL: Optional, auto-detected from request headers in most cases
# Only needed if auto-detection fails or for specific deployment scenarios
AUTH_URL="http://localhost:3000"

# NEXTAUTH_SECRET: Legacy v4 alias (kept for backward compatibility)
# Note: AUTH_SECRET is the preferred v5 variable
NEXTAUTH_SECRET="your-secret-key-change-in-production"

# Email
EMAIL_FROM="noreply@crunchycone.app"

# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Authentication Providers - Enable/Disable (client-accessible)
NEXT_PUBLIC_ENABLE_EMAIL_PASSWORD=true
NEXT_PUBLIC_ENABLE_MAGIC_LINK=true
NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=false
NEXT_PUBLIC_ENABLE_GITHUB_AUTH=false

# OAuth Providers (optional)
# Google OAuth
# NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=true
# GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
# GOOGLE_CLIENT_SECRET="GOCSPX-your-google-client-secret"

# GitHub OAuth
# NEXT_PUBLIC_ENABLE_GITHUB_AUTH=true
# GITHUB_CLIENT_ID="your-github-client-id"
# GITHUB_CLIENT_SECRET="your-github-client-secret"

CRUNCHYCONE_EMAIL_PROVIDER="console"
CRUNCHYCONE_EMAIL_FROM_DISPLAY="Crunchy Cone"
# Email Provider Configuration (uncomment as needed)
# SENDGRID_API_KEY="your-sendgrid-api-key"
# RESEND_API_KEY="your-resend-api-key"
# AWS_ACCESS_KEY_ID="your-aws-access-key"
# AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
# AWS_REGION="us-east-1"
# CRUNCHYCONE_SMTP_HOST="smtp.gmail.com"
# CRUNCHYCONE_SMTP_PORT="587"
# CRUNCHYCONE_SMTP_SECURE="false"
# CRUNCHYCONE_SMTP_USER=""
# CRUNCHYCONE_SMTP_PASS=""
#
# Storage Provider Configuration
CRUNCHYCONE_STORAGE_PROVIDER="localstorage"
CRUNCHYCONE_LOCALSTORAGE_PATH="./uploads"
CRUNCHYCONE_LOCALSTORAGE_BASE_URL="/api/storage/files"

# Logging Configuration
# LOG_LEVEL: debug | info | warn | error (default: debug)
LOG_LEVEL="debug"
# LOG_FORMAT: json | pretty (default: pretty)
LOG_FORMAT="pretty"
# LOG_USE_LOCALTIME: true | false (default: false for UTC timestamps)
LOG_USE_LOCALTIME="true"
# LOG_SANITIZE_PII: true | false (default: true in production, false in development)
# LOG_SANITIZE_PII="true"
# CYCLIC_LOG: true | false (default: false, stores up to 10k rows in app.log)
CYCLIC_LOG="true"

<!-- Email Heading Component -->
<mj-text
  font-size="{{ fontSize | default: '28px' }}"
  font-weight="{{ theme_heading_weight | default: 'bold' }}"
  color="{{ color | default: theme_primary | default: '#000000' }}"
  align="{{ align | default: 'center' }}"
  padding-bottom="{{ paddingBottom | default: '20px' }}"
>
  {{ text }}
</mj-text>
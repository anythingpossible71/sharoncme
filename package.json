{
  "name": "crunchycone-vanilla-starter-project",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/validate-admin-files.js && NODE_ENV=development NODE_OPTIONS=\"--no-deprecation\" next dev",
    "dev:turbo": "node scripts/validate-admin-files.js && NODE_ENV=development NODE_OPTIONS=\"--no-deprecation\" next dev --turbopack",
    "dev:platform": "node scripts/dev-platform.js",
    "dev:open": "node scripts/dev-open.js ${npm_config_port}",
    "dev:restart": "node scripts/dev-restart.js",
    "build": "npx prisma generate && npm run typecheck && node scripts/validate-admin-files.js && next build",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "build:clean": "rm -rf .next && npm run build",
    "verify:production": "npx prisma generate && npm run typecheck && npm run lint && rm -rf .next && npm run build",
    "start": "next start",
    "lint": "eslint .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "setup": "node scripts/auto-setup.js",
    "setup:force": "node scripts/auto-setup.js --force",
    "setup:verbose": "node scripts/auto-setup.js --verbose",
    "reset": "node scripts/reset.js",
    "setup-env": "node scripts/reset.js --jwt-only",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:reset": "rm -f db/prod.db && prisma migrate dev --name init && prisma db seed",
    "screenshots": "node scripts/generate-page-screenshots.js",
    "screenshots:refresh": "node scripts/generate-page-screenshots.js",
    "hooks:install": "node scripts/install-hooks.js",
    "hooks:remove": "rm -f .git/hooks/pre-commit"
  },
  "dependencies": {

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id             String    @id @default("")
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt
  deleted_at     DateTime?
  
  email          String    @unique
  name           String?   // Added for Auth.js compatibility
  image          String?   // Added for Auth.js compatibility
  emailVerified  DateTime? // Added for Auth.js compatibility
  password       String?
  last_signed_in DateTime?
  admin_theme    String?   @default("pistachio-almond") // User's preferred admin theme
  
  profile        UserProfile?
  roles          UserRole[]
  
  // Auth.js relationships
  accounts       Account[]
  sessions       Session[]
  
  // Blog posts
  blogPosts      BlogPost[]
  
  @@index([email])
  @@index([deleted_at])
}

model UserProfile {
  id         String    @id @default("")
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?
  
  user_id    String    @unique
  first_name String?
  last_name  String?
  
  user       User      @relation(fields: [user_id], references: [id])
  
  @@index([user_id])
  @@index([deleted_at])
}

model Role {
  id         String    @id @default("")
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?
  
  name       String    @unique
  
  users      UserRole[]
  
  @@index([name])
  @@index([deleted_at])
}

model UserRole {
  id         String    @id @default("")
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?
  
  user_id    String
  role_id    String
  
  user       User      @relation(fields: [user_id], references: [id])
  role       Role      @relation(fields: [role_id], references: [id])
  
  @@unique([user_id, role_id])
  @@index([user_id])
  @@index([role_id])
  @@index([deleted_at])
}

// ============================================
// Auth.js Required Models
// ============================================

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String?
  access_token             String?
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String?
  session_state            String?
  refresh_token_expires_in Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default("")
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PageTemplate {
  id                String    @id @default("")
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
  deleted_at        DateTime?
  
  title             String
  path              String    @unique
  dev_instructions  String    // What developers can do with this page
  preview_image     String?   // Path to preview screenshot
  requires_login    Boolean   @default(false) // Whether the page requires authentication
  
  @@index([path])
  @@index([deleted_at])
}

model AppSettings {
  id                String    @id @default("")
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
  deleted_at        DateTime?

  app_name          String
  app_description   String?
  app_logo_url      String?
  app_preview_image_url String?
  slug              String?   @unique

  // Website address settings
  subdomain         String?
  domain_type       String?   // 'customize', 'own', 'purchase'
  custom_domain     String?

  @@unique([id])
  @@index([deleted_at])
}

model TeamMember {
  id         String    @id @default("")
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  name       String
  role       String
  bio        String?
  avatar_url String?
  order      Int       @default(0) // For ordering team members

  // Social links (stored as JSON string or separate fields)
  github_url     String?
  linkedin_url   String?
  twitter_url    String?
  email          String?

  @@index([deleted_at])
  @@index([order])
}

model ContactMessage {
  id         String    @id @default("")
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?
  
  name       String
  email      String
  subject    String?
  message    String
  read       Boolean   @default(false) // Whether the message has been read
  replied    Boolean   @default(false) // Whether a reply has been sent
  
  @@index([deleted_at])
  @@index([email])
  @@index([created_at])
  @@index([read])
}

model BlogPost {
  id          String    @id @default("")
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?
  
  title       String
  slug        String    @unique
  content     String    // Serialized Lexical editor state (JSON)
  excerpt     String?   // Optional excerpt for preview
  status      String    @default("draft") // "draft" | "published"
  author_id   String    // User who created the post
  published_at DateTime? // When post was published (null for drafts)
  
  author      User      @relation(fields: [author_id], references: [id])
  
  @@index([slug])
  @@index([status])
  @@index([author_id])
  @@index([published_at])
  @@index([deleted_at])
}

// ============================================
// Contact Form System
// ============================================

model ContactSubmission {
  id             String    @id @default("")    // ULID string
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt
  deleted_at     DateTime?                     // Soft delete
  
  // Contact information
  name           String                        // Required
  phone          String                        // Required
  email          String?                       // Optional
  
  // Activity details
  activityType   String                        // Required - chosen activity
  
  // Date fields (conditional)
  birthdate      DateTime?                     // Estimated birth date
  babyBirthdate  DateTime?                     // Baby's birthday
  
  // Additional information
  message        String?                       // Comments/notes
  howFound       String?                       // How they found the site
  referrerName   String?                       // Who referred them
  
  @@index([created_at])
  @@index([deleted_at])
  @@index([activityType])
}